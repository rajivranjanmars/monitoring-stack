{
  "uid": "nexus-redis",
  "title": "Nexus — Redis",
  "tags": ["nexus", "redis", "cache"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [{ "refId": "A", "expr": "redis_connected_clients", "legendFormat": "Clients" }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Cache Hit Rate %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "Hit Rate"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 80 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "title": "Memory Used",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [{ "refId": "A", "expr": "redis_memory_used_bytes", "legendFormat": "RAM" }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "Total Keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [{ "refId": "A", "expr": "sum(redis_db_keys)", "legendFormat": "Keys" }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Evicted Keys (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [{ "refId": "A", "expr": "redis_evicted_keys_total", "legendFormat": "Evicted" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 100 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 6,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [{ "refId": "A", "expr": "redis_uptime_in_seconds", "legendFormat": "Uptime" }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Commands Processed / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        { "refId": "A", "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "ops/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      }
    },
    {
      "id": 8,
      "title": "Cache Hits vs Misses / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        { "refId": "A", "expr": "rate(redis_keyspace_hits_total[1m])",   "legendFormat": "hits/s" },
        { "refId": "B", "expr": "rate(redis_keyspace_misses_total[1m])", "legendFormat": "misses/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hits/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "misses/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 9,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        { "refId": "A", "expr": "redis_memory_used_bytes",      "legendFormat": "Used" },
        { "refId": "B", "expr": "redis_memory_max_bytes",       "legendFormat": "Max limit" },
        { "refId": "C", "expr": "redis_memory_used_rss_bytes",  "legendFormat": "RSS (OS view)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      }
    },
    {
      "id": 10,
      "title": "Connected Clients Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        { "refId": "A", "expr": "redis_connected_clients",      "legendFormat": "Connected" },
        { "refId": "B", "expr": "redis_blocked_clients",        "legendFormat": "Blocked" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 11,
      "title": "Keys by DB",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        { "refId": "A", "expr": "redis_db_keys", "legendFormat": "{{db}} keys" },
        { "refId": "B", "expr": "redis_db_expiring_keys", "legendFormat": "{{db}} expiring" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 12,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        { "refId": "A", "expr": "rate(redis_net_input_bytes_total[1m])",  "legendFormat": "↓ in" },
        { "refId": "B", "expr": "rate(redis_net_output_bytes_total[1m])", "legendFormat": "↑ out" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      }
    }
  ]
}
