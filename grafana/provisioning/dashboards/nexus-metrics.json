{
  "uid": "nexus-metrics",
  "title": "Nexus — Metrics",
  "tags": ["nexus", "metrics"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_requests_total[1h]))",
          "legendFormat": "Requests"
        }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 2,
      "title": "Error Rate (4xx + 5xx %)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_requests_total{status_code=~\"[45]..\"}[5m])) or vector(0)) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "Error %"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "title": "P50 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p50"
        }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1500 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "title": "P95 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p95"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1000 },
            { "color": "red", "value": 3000 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 5,
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p99"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2000 },
            { "color": "red", "value": 8000 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 6,
      "title": "Req/s (5xx errors)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "5xx/s"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "decimals": 3,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.01 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 7,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(8, sum by (method, handler) (rate(http_requests_total[1m])))",
          "legendFormat": "{{method}} {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8,
      "title": "Requests by Status Class",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{status_code=~\"2..\"}[1m])) or vector(0)",
          "legendFormat": "2xx success"
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[1m])) or vector(0)",
          "legendFormat": "4xx client errors"
        },
        {
          "refId": "C",
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) or vector(0)",
          "legendFormat": "5xx server errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx client errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx server errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 9,
      "title": "Latency Percentiles (all endpoints)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "title": "P95 Latency per Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000)",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 0 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 11,
      "title": "Avg Request Size by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (rate(http_request_size_bytes_sum[5m])) / sum by (handler) (rate(http_request_size_bytes_count[5m]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 12,
      "title": "Avg Response Size by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (rate(http_response_size_bytes_sum[5m])) / sum by (handler) (rate(http_response_size_bytes_count[5m]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 13,
      "title": "4xx Errors by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler, status_code) (rate(http_requests_total{status_code=~\"4..\"}[5m])) or vector(0)",
          "legendFormat": "{{status_code}} {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "yellow", "mode": "fixed" }
        }
      }
    },
    {
      "id": 14,
      "title": "5xx Errors by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler, status_code) (rate(http_requests_total{status_code=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "{{status_code}} {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    }
  ]
}
