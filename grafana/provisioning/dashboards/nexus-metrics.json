{
  "uid": "nexus-metrics",
  "title": "Nexus — Metrics",
  "tags": ["nexus", "metrics"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler, method) (rate(http_requests_total{job=\"backend_proxy\"}[1m]))",
          "legendFormat": "{{method}} {{handler}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 2,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"backend_proxy\"}[5m]))) * 1000",
          "legendFormat": "p95 {{handler}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_requests_total{job=\"backend_proxy\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"backend_proxy\"}[5m]))",
          "legendFormat": "5xx error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active Requests (in-flight)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "http_requests_in_progress{job=\"backend_proxy\"}",
          "legendFormat": "in-flight"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20 } } }
    },
    {
      "id": 5,
      "title": "Total Requests (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_requests_total{job=\"backend_proxy\"}[1h]))",
          "legendFormat": "Requests"
        }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Total Errors (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_requests_total{job=\"backend_proxy\", status_code=~\"5..\"}[1h]))",
          "legendFormat": "Errors"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 7,
      "title": "P50 Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"backend_proxy\"}[5m]))) * 1000",
          "legendFormat": "p50"
        }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 8,
      "title": "P99 Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-nexus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"backend_proxy\"}[5m]))) * 1000",
          "legendFormat": "p99"
        }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    }
  ]
}
